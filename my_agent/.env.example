# Copy to .env and fill in real values:  cp .env.example .env
# Never commit .env (it is gitignored).

# Google Gen AI (when not using Vertex)
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_API_KEY=your-google-generative-language-api-key

# MongoDB
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?appName=YourApp
MONGODB_DB=medical_agent
MONGODB_COLLECTION=medical_image_reports


# Gmail: use an App Password, not your normal password — https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS="your-app-password-or-paste-without-spaces"
SMTP_FROM=you@gmail.com
SMTP_USE_TLS=true

# LLM: GEMINI_MODEL if set, else ADK_MODEL, else built-in default in code.
# Cloud (example):
GEMINI_MODEL=gemini-2.5-flash
# Local Ollama (install litellm for adk to use local ollama models):
# ADK_MODEL=ollama/llama3.2-vision:latest
# ADK_MODEL=ollama/qwen2.5vl:7b
#OPTIONAL
# OLLAMA_API_BASE=http://127.0.0.1:11434
